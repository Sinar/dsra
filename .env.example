# ==============================================================================
# Email Configuration (required for Send to Sinar Project team feature)
# ==============================================================================
# Choose ONE of the following transport options:

# Option 1: Mailgun HTTP API (recommended for production)
# Get your API key from https://app.mailgun.com/app/account/security/api_keys
# Replace YOUR_API_KEY and YOUR_DOMAIN with actual values:
# MAILER_DSN=mailgun+api://YOUR_API_KEY@default?domain=mg.yourdomain.com

# Option 2: Custom SMTP server
# Format: smtp://USERNAME:PASSWORD@HOST:PORT
# MAILER_DSN=smtp://user:pass@smtp.example.com:587

# Recipient and sender email addresses:
MAILER_TO=team@sinarproject.org
MAILER_FROM=noreply@sinarproject.org

# ==============================================================================
# Server URL (required for download links in email)
# ==============================================================================
# The public URL where this instance is accessible. Used to generate download
# links for encrypted assessment files sent in the email.
BASE_URL=https://dsra.sinarproject.org

# ==============================================================================
# GPG Encryption (required for server-side encrypted storage)
# ==============================================================================
# Key ID to use for encrypting assessment files at rest. Must match the
# auto-generated key in the container (set to team@sinarproject.org).
GPG_KEY_ID=team@sinarproject.org

# Directory for storing encrypted assessment files (relative or absolute path).
# Default: /opt/app-root/src/data (inside container)
DATA_DIR=/opt/app-root/src/data

# ==============================================================================
# After configuring, copy this file to .env:
# cp .env.example .env
# Docker Compose will read these variables from .env automatically.
